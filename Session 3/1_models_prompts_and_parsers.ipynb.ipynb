# CELL 1: Imports and Client Initialization
import os
from pydantic import BaseModel, Field
from langchain_openai import ChatOpenAI
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.messages import SystemMessage, HumanMessage, AIMessage
from langchain_core.output_parsers import PydanticOutputParser, StrOutputParser

# Ensure API Key validation is clean
if "OPENAI_API_KEY" not in os.environ:
    print("Warning: Please set your OPENAI_API_KEY environment variable.")

# Initialize standard Chat Model
model = ChatOpenAI(model="gpt-4o-mini", temperature=0)

# ==========================================
# CELL 2: Core Core Messages Component
# ==========================================
messages = [
    SystemMessage(content="You are a strict technical compliance officer specialized in data governance."),
    HumanMessage(content="What are the essential elements of a production-ready data cataloging framework?")
]
response = model.invoke(messages)
print("--- Basic Chat Response ---")
print(response.content)

# ==========================================
# CELL 3: ChatPromptTemplate Component
# ==========================================
prompt_template = ChatPromptTemplate.from_template(
    "Translate the following professional instruction into business-level French:\nText: {text}"
)
formatted_prompt = prompt_template.format_messages(text="Initialize the data ingestion pipeline and mask sensitive fields.")

translation_chain = prompt_template | model | StrOutputParser()
translation_output = translation_chain.invoke({"text": "Initialize the data ingestion pipeline and mask sensitive fields."})
print("\n--- Prompt Template Output ---")
print(translation_output)

# ==========================================
# CELL 4: Structured Output via Pydantic
# ==========================================
class SchemaValidationReport(BaseModel):
    is_compliant: bool = Field(description="True if the schema strictly satisfies enterprise governance rules.")
    detected_violations: list[str] = Field(description="List of specific structural or security violations found.")
    remediation_steps: str = Field(description="Step-by-step technical instructions to fix the schema.")

# Instantiate parser
parser = PydanticOutputParser(pydantic_object=SchemaValidationReport)

structured_prompt = ChatPromptTemplate.from_template(
    "Analyze the following schema configuration and evaluate it against standard security guardrails.\n"
    "{format_instructions}\n"
    "Schema: {schema_input}"
)

# Bind structural requirements
partial_prompt = structured_prompt.partial(format_instructions=parser.get_format_instructions())
structured_chain = partial_prompt | model | parser

sample_schema = "{'table': 'customer_logs', 'columns': [{'name': 'ssn', 'type': 'STRING', 'masked': false}]}"
try:
    report = structured_chain.invoke({"schema_input": sample_schema})
    print("\n--- Structured Output Object Parsed Successfully ---")
    print(f"Compliant: {report.is_compliant}")
    print(f"Violations: {report.detected_violations}")
    print(f"Remediation: {report.remediation_steps}")
except Exception as e:
    print(f"Parsing failed during validation step: {e}")