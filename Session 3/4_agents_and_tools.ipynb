# CELL 1: Imports
from langchain_core.tools import tool
from langchain_openai import ChatOpenAI
from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder
from langchain_core.utils.function_calling import convert_to_openai_tool
from langchain.agents.format_scratchpad.openai_tools import format_to_openai_tool_messages
from langchain.agents.output_parsers.openai_tools import OpenAIToolsAgentOutputParser
from langchain.agents import AgentExecutor

# ==========================================
# CELL 2: Custom Engineering Tools Definition
# ==========================================
@tool
def calculate_network_throughput(bandwidth_gbps: float, latency_ms: float) -> float:
    """Calculates theoretical optimal system transmission rates given bandwidth and network latency values."""
    if latency_ms <= 0:
        return 0.0
    return (bandwidth_gbps * 1000) / latency_ms

# Package tools registry lists
tools_registry = [calculate_network_throughput]

# ==========================================
# CELL 3: Model Tool Binding Interface
# ==========================================
llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)
# Dynamic model schema registration step
llm_with_tools = llm.bind_tools(tools_registry)

# Verify declaration framework structure
print("System tools registry mapping setup successfully.")

# ==========================================
# CELL 4: ReAct Agent Pipeline Construction
# ==========================================
agent_prompt = ChatPromptTemplate.from_messages([
    ("system", "You are an infrastructure system optimization agent equipped with analytical diagnostic calculators."),
    ("human", "{input}"),
    MessagesPlaceholder(variable_name="agent_scratchpad")
])

# Create runnable execution graph chain
agent_graph = (
    {
        "input": lambda x: x["input"],
        "agent_scratchpad": lambda x: format_to_openai_tool_messages(x["intermediate_steps"])
    }
    | agent_prompt
    | llm_with_tools
    | OpenAIToolsAgentOutputParser()
)

# Initialize core agent orchestrator engine
agent_executor = AgentExecutor(agent=agent_graph, tools=tools_registry, verbose=True)

# Run verification evaluation
query_input = "Determine optimal network performance thresholds if our network allocation path has 10 Gbps bandwidth with 5ms systemic latency."
print("\n--- Initializing Autonomous Agent Processing Execution ---")
execution_output = agent_executor.invoke({"input": query_input})
print("\n--- Output Summary Results ---")
print(execution_output["output"])