# CELL 1: Imports
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.output_parsers import StrOutputParser
from langchain_core.runnables import RunnablePassthrough, RunnableParallel
from langchain_openai import ChatOpenAI

model = ChatOpenAI(model="gpt-4o-mini", temperature=0.2)

# ==========================================
# CELL 2: Simple Sequence (LCEL Composition)
# ==========================================
step_one_prompt = ChatPromptTemplate.from_template("Identify the core technical topic in this engineering log: {log}")
step_two_prompt = ChatPromptTemplate.from_template("Generate a production mitigation strategy for the following technical topic: {topic}")

# Chain sequential pipeline logic cleanly
chain_one = step_one_prompt | model | StrOutputParser()
full_sequential_chain = (
    {"topic": chain_one} 
    | step_two_prompt 
    | model 
    | StrOutputParser()
)

sample_log = "Error: Connection timeout encountered on vector store indexing batch 404 after 30000ms."
sequential_result = full_sequential_chain.invoke({"log": sample_log})
print("--- Sequential Chain Strategy Output ---")
print(sequential_result)

# ==========================================
# CELL 3: Parallel Logic Branching (RunnableParallel)
# ==========================================
security_audit_prompt = ChatPromptTemplate.from_template("Perform a pure security risk analysis for this design concept: {concept}")
performance_audit_prompt = ChatPromptTemplate.from_template("Perform a performance scaling evaluation for this design concept: {concept}")

security_branch = security_audit_prompt | model | StrOutputParser()
performance_branch = performance_audit_prompt | model | StrOutputParser()

parallel_review_chain = RunnableParallel(
    security_analysis=security_branch,
    performance_analysis=performance_branch
)

sample_concept = "Deploying a global distributed Redis cache layer directly on top of raw unstructured customer document storage buckets."
parallel_outputs = parallel_review_chain.invoke({"concept": sample_concept})

print("\n--- Parallel Branching Analysis ---")
print("[Security]:", parallel_outputs['security_analysis'][:300], "...")
print("[Performance]:", parallel_outputs['performance_analysis'][:300], "...")