# CELL 1: Imports
import numpy as np
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_openai import OpenAIEmbeddings
from langchain_community.vectorstores import FAISS
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.output_parsers import StrOutputParser
from langchain_core.runnables import RunnablePassthrough
from langchain_openai import ChatOpenAI

# Initialize core model and embeddings
embeddings = OpenAIEmbeddings(model="text-embedding-3-small")
llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)

# ==========================================
# CELL 2: Chunking & Text Splitters
# ==========================================
raw_document_corpus = """
Enterprise Architecture Blueprint:
Section 1.1: Data Mesh Implementation Rules. All data domains must implement explicit interface contracts.
Section 1.2: Security Guardrails. All downstream LLM workloads require runtime column-masking routines on PII data attributes.
Section 1.3: Storage Engine. High-dimensional vectors representing document chunks must reside in isolated vector indices supporting ANN searches.
"""

splitter = RecursiveCharacterTextSplitter(chunk_size=120, chunk_overlap=20)
chunked_docs = splitter.create_documents([raw_document_corpus])
print(f"Generated {len(chunked_docs)} structured chunks from corpus text.")

# ==========================================
# CELL 3: Embeddings & Pure Cosine Similarity
# ==========================================
vector_a = embeddings.embed_query("Data mesh implementation rules require contracts.")
vector_b = embeddings.embed_query("Enterprise domain contracts framework.")

def compute_cosine_similarity(v1, v2):
    dot_product = np.dot(v1, v2)
    norm_v1 = np.linalg.norm(v1)
    norm_v2 = np.linalg.norm(v2)
    return dot_product / (norm_v1 * norm_v2)

similarity_score = compute_cosine_similarity(vector_a, vector_b)
print(f"Calculated Semantic Vector Cosine Similarity: {similarity_score:.4f}")

# ==========================================
# CELL 4: Vector Store & Retrieval Augmented Generation (RAG)
# ==========================================
# Vector store initialization in memory
vector_db = FAISS.from_documents(chunked_docs, embeddings)
retriever = vector_db.as_retriever(search_kwargs={"k": 2})

rag_prompt = ChatPromptTemplate.from_template(
    "Context raw documents:\n{context}\n\nQuestion: {question}\nAnswer strict and technical:"
)

def format_retrieved_docs(docs):
    return "\n---\n".join([doc.page_content for doc in docs])

# Complete RAG Pipeline construction using LCEL
rag_pipeline = (
    {"context": retriever | format_retrieved_docs, "question": RunnablePassthrough()}
    | rag_prompt
    | llm
    | StrOutputParser()
)

query = "What security guidelines are defined for downstream LLM workloads?"
rag_response = rag_pipeline.invoke(query)
print("\n--- Synthesized RAG Context Engine Response ---")
print(rag_response)